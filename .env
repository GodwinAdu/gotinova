NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# PAYSTACK (Payment Processing)
# ═══════════════════════════════════════════════════════════
# 1. Go to https://paystack.com and create an account
# 2. Settings > API Keys & Webhooks
# 3. Copy your PUBLIC key (starts with pk_test_ or pk_live_)
